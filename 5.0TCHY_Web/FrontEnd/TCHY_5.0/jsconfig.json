{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",

    "moduleResolution": "Bundler", 

    "paths": {
      "@/*": ["./src/*"]
    },
    
    "jsx": "preserve",
    "checkJs": false,
    
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,

    "types": ["vite/client"]
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}